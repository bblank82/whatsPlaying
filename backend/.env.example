# How often (seconds) to re-scan the network for new Apple TV devices
SCAN_INTERVAL=30

# How often (seconds) to poll each device for now-playing state
POLL_INTERVAL=5

# TMDB API Key for metadata fetching
TMDB_API_KEY=

# Comma-separated IPs for Apple TVs on other subnets that mDNS can't reach
EXTRA_HOSTS=

# Comma-separated IPs for Kaleidescape players
KALEIDESCAPE_HOSTS=

# Comma-separated IPs for Sony Blu-ray players
SONY_HOSTS=

# Comma-separated identifiers for devices to ignore
IGNORED_DEVICES=
